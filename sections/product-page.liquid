{% assign product = product %}

<div class="product-page-wrapper">
  <div class="section-wrapper">

    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo;
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a> &rsaquo;
      {% endif %}
      <span>{{ product.title }}</span>
    </div>

    <div class="product-page-grid">

      <!-- Images -->
      <div class="product-images">
        <div class="main-image-wrap">
          <img id="main-product-image"
               src="{{ product.featured_image | img_url: '800x' }}"
               alt="{{ product.title }}" loading="lazy">
        </div>
        <div class="thumbnail-row">
          {% for image in product.images %}
            <img src="{{ image | img_url: '120x' }}" alt="{{ product.title }}"
                 class="thumb-img {% if forloop.first %}active{% endif %}"
                 onclick="document.getElementById('main-product-image').src='{{ image | img_url: '800x' }}'">
          {% endfor %}
        </div>
      </div>

      <!-- Details -->
      <div class="product-details">
        <div class="product-brand-tag">{{ product.vendor }}</div>
        <h1 class="product-name">{{ product.title }}</h1>

        <div class="product-rating">⭐⭐⭐⭐⭐ <span>({{ product.metafields.reviews.rating_count | default: '0' }} reviews)</span></div>

        <div class="product-price-block">
          <span class="big-price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="old-price">{{ product.compare_at_price | money }}</span>
            {% assign saving = product.compare_at_price | minus: product.price %}
            <span class="saving-badge">Save {{ saving | money }}</span>
          {% endif %}
        </div>

        <div class="delivery-info-box">
          <div class="delivery-row"><span>⚡</span><div>**Same-Day Delivery**<p>Order before 11am on orders over £29</p></div></div>
          <div class="delivery-row"><span>🚚</span><div>**Free Standard Delivery**<p>On all orders over £29</p></div></div>
          <div class="delivery-row"><span>🔄</span><div>**Free Returns**<p>Within 30 days of purchase</p></div></div>
        </div>

        {% unless product.has_only_default_variant %}
          <div class="variant-section">
            {% for option in product.options_with_values %}
              <div class="variant-group">
                <label class="variant-label">{{ option.name }}</label>
                <div class="variant-buttons">
                  {% for value in option.values %}
                    <button class="variant-btn" data-option="{{ option.position }}" data-value="{{ value }}">{{ value }}</button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <form action="/cart/add" method="post" class="add-to-cart-form">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div class="qty-row">
            <div class="qty-selector">
              <button type="button" onclick="changeQty(-1)">−</button>
              <input type="number" name="quantity" value="1" min="1" id="qty-input">
              <button type="button" onclick="changeQty(1)">+</button>
            </div>
            <button type="submit" class="add-to-cart-btn big-btn">🛒 Add to Cart</button>
          </div>
          <a href="/checkout" class="buy-now-btn">⚡ Buy Now</a>
        </form>

        <div class="trust-badges">
          <span>🔒 Secure Payment</span>
          <span>✅ Genuine Products</span>
          <span>📞 24/7 Support</span>
        </div>

        <div class="product-description">
          <h3>Product Details</h3>
          {{ product.description }}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.product-page-wrapper { background: #f4f4f4; padding: 20px 0; }
.breadcrumb { font-size: 13px; color: #888; margin-bottom: 20px; }
.breadcrumb a { color: #e8001d; }
.product-page-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; background: #fff; border-radius: 16px; padding: 30px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
.main-image-wrap { border: 1px solid #eee; border-radius: 12px; padding: 20px; text-align: center; background: #fafafa; margin-bottom: 12px; }
.main-image-wrap img { max-height: 400px; margin: 0 auto; object-fit: contain; }
.thumbnail-row { display: flex; gap: 8px; flex-wrap: wrap; }
.thumb-img { width: 70px; height: 70px; object-fit: contain; border: 2px solid #eee; border-radius: 8px; cursor: pointer; padding: 4px; transition: border-color 0.2s; }
.thumb-img:hover, .thumb-img.active { border-color: #e8001d; }
.product-brand-tag { font-size: 12px; color: #e8001d; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.product-name { font-size: 24px; font-weight: 800; color: #1a1a1a; margin-bottom: 10px; line-height: 1.3; }
.product-rating { font-size: 13px; color: #888; margin-bottom: 16px; }
.product-price-block { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.big-price { font-size: 32px; font-weight: 800; color: #e8001d; }
.old-price { font-size: 16px; color: #aaa; text-decoration: line-through; }
.saving-badge { background: #fff0f2; color: #e8001d; font-size: 13px; font-weight: 700; padding: 4px 10px; border-radius: 6px; }
.delivery-info-box { background: #f9f9f9; border: 1px solid #eee; border-radius: 12px; padding: 16px; margin-bottom: 20px; }
.delivery-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
.delivery-row:last-child { margin-bottom: 0; }
.delivery-row span { font-size: 20px; }
.delivery-row strong { font-size: 13.5px; color: #1a1a1a; }
.delivery-row p { font-size: 12px; color: #888; margin: 0; }
.variant-section { margin-bottom: 20px; }
.variant-group { margin-bottom: 14px; }
.variant-label { font-size: 13px; font-weight: 700; color: #333; display: block; margin-bottom: 8px; }
.variant-buttons { display: flex; gap: 8px; flex-wrap: wrap; }
.variant-btn { padding: 7px 16px; border: 2px solid #ddd; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; background: #fff; transition: all 0.2s; }
.variant-btn:hover, .variant-btn.selected { border-color: #e8001d; color: #e8001d; background: #fff0f2; }
.qty-row { display: flex; gap: 12px; margin-bottom: 12px; align-items: center; }
.qty-selector { display: flex; align-items: center; border: 2px solid #ddd; border-radius: 8px; overflow: hidden; }
.qty-selector button { background: #f4f4f4; border: none; padding: 10px 16px; font-size: 18px; cursor: pointer; font-weight: 700; }
.qty-selector input { width: 50px; border: none; text-align: center; font-size: 15px; font-weight: 700; outline: none; }
.big-btn { flex: 1; padding: 14px; font-size: 15px; border-radius: 8px; }
.buy-now-btn { display: block; width: 100%; background: #1a1a1a; color: #fff; text-align: center; padding: 14px; border-radius: 8px; font-size: 15px; font-weight: 700; margin-bottom: 16px; transition: background 0.2s; }
.buy-now-btn:hover { background: #333; }
.trust-badges { display: flex; gap: 16px; flex-wrap: wrap; font-size: 12.5px; color: #555; font-weight: 600; padding: 14px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; margin-bottom: 20px; }
.product-description h3 { font-size: 16px; font-weight: 700; margin-bottom: 12px; }
.product-description { font-size: 14px; color: #555; line-height: 1.7; }
@media(max-width: 768px) { .product-page-grid { grid-template-columns: 1fr; } .big-price { font-size: 26px; } .product-name { font-size: 20px; } }
</style>

<script>
function changeQty(change) {
  const input = document.getElementById('qty-input');
  let val = parseInt(input.value) + change;
  if (val < 1) val = 1;
  input.value = val;
}
document.querySelectorAll('.variant-btn').forEach(btn => {
  btn.addEventListener('click', function () {
    const group = this.closest('.variant-buttons');
    group.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('selected'));
    this.classList.add('selected');
  });
});
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [],
  "presets": [{ "name": "Product Page" }]
}
{% endschema %}
