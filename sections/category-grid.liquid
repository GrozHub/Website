<section class="section-block" style="background:#f4f4f4;">
  <div class="section-wrapper">
    <div class="section-title-wrap">
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <a href="/collections/all" class="view-all-link">View All →</a>
    </div>

    <div class="category-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-icon">{{ block.settings.icon }}</div>
          <div class="category-name">{{ block.settings.name }}</div>
          <div class="category-count">{{ block.settings.count }}</div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji Icon", "default": "📱" },
        { "type": "text", "id": "name", "label": "Category Name", "default": "Phones" },
        { "type": "text", "id": "count", "label": "Item Count", "default": "500+ items" },
        { "type": "url", "id": "link", "label": "Category Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "icon": "📱", "name": "Phones", "count": "500+ items" } },
        { "type": "category", "settings": { "icon": "💻", "name": "Laptops", "count": "300+ items" } },
        { "type": "category", "settings": { "icon": "📺", "name": "TVs", "count": "200+ items" } },
        { "type": "category", "settings": { "icon": "🎮", "name": "Gaming", "count": "400+ items" } },
        { "type": "category", "settings": { "icon": "🎧", "name": "Audio", "count": "350+ items" } },
        { "type": "category", "settings": { "icon": "⌚", "name": "Wearables", "count": "150+ items" } }
      ]
    }
  ]
}
{% endschema %}
