<div class="section-wrapper">
  <div class="search-header">
    <h1>🔍 Search Results</h1>
    {% if search.performed %}
      <p>
        {% if search.results_count == 0 %}
          No results for **"{{ search.terms }}"**
        {% else %}
          {{ search.results_count }} results for **"{{ search.terms }}"**
        {% endif %}
      </p>
    {% endif %}
  </div>

  <!-- Search Bar -->
  <form action="/search" method="get" class="search-page-form">
    <div class="header-search" style="max-width:600px; margin-bottom:30px;">
      <input type="text" name="q" value="{{ search.terms }}"
             placeholder="Search for products, brands..." autocomplete="off">
      <button type="submit">🔍 Search</button>
    </div>
  </form>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <div class="no-results">
        <div style="font-size:60px; margin-bottom:16px;">🔍</div>
        <h2>No results found</h2>
        <p>Try different keywords or browse our categories below.</p>
        <a href="/collections/all" class="hero-btn" style="display:inline-block; margin-top:20px;">
          Browse All Products →
        </a>
      </div>
    {% else %}
      <div class="product-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
</div>

<style>
.search-header { margin-bottom: 20px; }
.search-header h1 { font-size: 26px; font-weight: 800; margin-bottom: 6px; }
.search-header p { color: #666; font-size: 14px; }
.no-results { text-align: center; padding: 60px 20px; background: #fff; border-radius: 16px; }
.no-results h2 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
.no-results p { color: #888; }
</style>

{% schema %}
{
  "name": "Search Results",
  "settings": [],
  "presets": [{ "name": "Search Results" }]
}
{% endschema %}
