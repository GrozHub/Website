[
  {
    "name": "theme_info",
    "theme_name": "JoyBuy Theme",
    "theme_version": "1.0.0",
    "theme_author": "JoyBuy",
    "theme_documentation_url": "https://joybuy.co.uk",
    "theme_support_url": "https://joybuy.co.uk/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Color",
        "default": "#e8001d"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary Color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page Background",
        "default": "#f4f4f4"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body Text Color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_link",
        "label": "Link Color",
        "default": "#e8001d"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "inter_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base Font Size (px)",
        "min": 12,
        "max": 18,
        "step": 1,
        "default": 14
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Store Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo Width (px)",
        "min": 80,
        "max": 300,
        "step": 10,
        "default": 160
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable Sticky Header",
        "default": true
      }
    ]
  },
  {
    "name": "Promo Strip",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_promo_strip",
        "label": "Show Promo Strip",
        "default": true
      },
      {
        "type": "color",
        "id": "promo_strip_bg",
        "label": "Promo Strip Background",
        "default": "#e8001d"
      },
      {
        "type": "color",
        "id": "promo_strip_text_color",
        "label": "Promo Strip Text Color",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show Product Vendor",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_rating",
        "label": "Show Star Rating",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_savings",
        "label": "Show Savings Badge",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_wishlist",
        "label": "Show Wishlist Button",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_ajax_cart",
        "label": "Enable AJAX Cart (No page reload)",
        "default": true
      },
      {
        "type": "number",
        "id": "free_delivery_threshold",
        "label": "Free Delivery Threshold (in pence)",
        "default": 2900
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "color",
        "id": "footer_bg",
        "label": "Footer Background Color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "footer_text_color",
        "label": "Footer Text Color",
        "default": "#999999"
      },
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show Payment Icons",
        "default": true
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_twitter",
        "label": "Twitter / X URL"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon Image"
      }
    ]
  }
]
